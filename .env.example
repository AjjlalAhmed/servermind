# ServerMind configuration — copy to `.env` and edit, OR just run `bun run setup`
# (the wizard writes everything below, including the two auth secrets, which you
# should NOT set by hand). `.env` is gitignored and never leaves your server.

# ── Authentication (written by `bun run setup-auth`) ─────────────────────────
# Password is argon2id, stored base64 (it contains `$`, which the .env loader
# would otherwise mangle). TOTP secret is base32. Leave blank to be prompted to
# run setup; never edit these by hand.
SERVERMIND_PASSWORD_HASH=
SERVERMIND_TOTP_SECRET=
SESSION_TTL_HOURS=12

# ── Networking ───────────────────────────────────────────────────────────────
# Default: localhost only. Reach it via SSH tunnel / Tailscale, or front it with
# a reverse proxy on a domain (set SECURE_COOKIES=1 then). See the README's
# "Accessing ServerMind" section.
BIND_HOST=127.0.0.1
PORT=5500
SECURE_COOKIES=
# Optional — your public domain, for display/reference only (set by the wizard).
SERVERMIND_DOMAIN=

# ── AI backend ───────────────────────────────────────────────────────────────
# "claude-code" → drives the local `claude` CLI (subscription, no API key).
# "openai"      → any OpenAI-compatible API (Gemini, Groq, OpenRouter, Ollama…).
AI_BACKEND=claude-code

# For AI_BACKEND=openai (e.g. free Gemini):
#   AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   AI_MODEL=gemini-2.0-flash
#   AI_API_KEY=<key from https://aistudio.google.com>
AI_BASE_URL=
AI_MODEL=
AI_API_KEY=

# For AI_BACKEND=claude-code:
CLAUDE_BIN=claude
MODEL=claude-sonnet-4-6
# CLAUDE_CODE_OAUTH_TOKEN=   # optional; usually unnecessary if `claude` is logged in

# ── PM2 ──────────────────────────────────────────────────────────────────────
# PM2 is per-user. To monitor another user's daemon (e.g. root's), use:
#   PM2_COMMAND=sudo -n /root/.bun/bin/pm2   (grant a NOPASSWD sudo rule for it)
PM2_COMMAND=pm2

# ── Monitored services (dashboard + allowlist) ───────────────────────────────
MONITORED_UNITS=nginx,caddy,mysql,mariadb,redis-server
# MANAGED_SERVICES=nginx,caddy,mysql,mysqld,mariadb,redis,redis-server,pm2-root,docker,fail2ban
# EXTRA_LOG_PATHS=   # extra roots read_log/cat may read, beyond /var/log

# ── Optional health probes ───────────────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
