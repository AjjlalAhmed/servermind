{
  "name": "servermind",
  "version": "1.0.0",
  "description": "ServerMind — Claude-powered VPS management assistant (Bun + Hono)",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "mcp": "bun run src/mcp-server.ts",
    "agent": "bun run src/agent-main.ts",
    "setup": "bun run src/setup.ts",
    "setup-auth": "bun run src/setup-auth.ts",
    "update": "bash update.sh",
    "uninstall": "bash uninstall.sh",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.0",
    "hono": "^4.10.3",
    "qrcode": "^1.5.4",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.7.0"
  }
}
