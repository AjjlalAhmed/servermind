{
  "name": "servermind-desktop",
  "version": "0.1.0",
  "description": "ServerMind Desktop — a secure SSH tunnel + dashboard window for your ServerMind controller. No domain, no reverse proxy, no certs.",
  "license": "MIT",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-static.js",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/ssh2": "^1.15.1",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "dev.servermind.desktop",
    "productName": "ServerMind",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "icon": "build/icon.png",
    "publish": {
      "provider": "github",
      "owner": "AjjlalAhmed",
      "repo": "servermind"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [{ "target": "dmg", "arch": ["universal"] }],
      "artifactName": "ServerMind.${ext}"
    },
    "dmg": {
      "title": "ServerMind",
      "artifactName": "ServerMind.${ext}"
    },
    "win": {
      "target": ["nsis"],
      "artifactName": "ServerMind-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Development",
      "artifactName": "ServerMind.${ext}"
    }
  }
}
